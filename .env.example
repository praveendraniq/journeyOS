# Server
PORT=8787
CLIENT_ORIGIN=http://localhost:5173
MOCK_MODE=true

# Sabre sandbox. Leave blank to use deterministic demo results.
SABRE_CLIENT_ID=
SABRE_CLIENT_SECRET=
SABRE_BASE_URL=https://api.cert.platform.sabre.com
SABRE_PCC=S5OM
# Sandbox uses OAuth v2. The server exchanges the credentials for a short-lived bearer token.
SABRE_OAUTH_VERSION=v2

# PayPal sandbox. Leave blank to use the demo checkout path.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox

# Vocal Bridge deployment. Account-level keys also require the agent UUID.
VOCAL_BRIDGE_API_KEY=
VOCAL_BRIDGE_API_URL=https://vocalbridgeai.com
VOCAL_BRIDGE_AGENT_ID=

# Landing AI (optional bonus receipt OCR)
LANDING_AI_API_KEY=
LANDING_AI_ENDPOINT=
