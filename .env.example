# Server
PORT=8787
CLIENT_ORIGIN=http://localhost:5173
MOCK_MODE=true

# Sabre Developer Hub Test OAuth v2. Copy User ID and Password from Applications.
SABRE_EPR_USERNAME=
SABRE_EPR_PASSWORD=
# Legacy aliases SABRE_CLIENT_ID / SABRE_CLIENT_SECRET are also supported.
SABRE_BASE_URL=https://api.cert.platform.sabre.com
SABRE_PCC=S5OM
# Sandbox uses OAuth v2. The server exchanges the credentials for a short-lived bearer token.
SABRE_OAUTH_VERSION=v2

# Hackathon OAuth v2 alternative. Use only this pair when SABRE_AUTH_VERSION=v2.
# S5OM is the hackathon PCC; never expose these in client/.env.local.
SABRE_AUTH_VERSION=v2
SABRE_V2_USER_ID=
SABRE_V2_PASSWORD=
SABRE_V2_PCC=S5OM
SABRE_V2_DOMAIN=EXT

# Google Places (New) server key. Keep separate from client/.env.local.
GOOGLE_PLACES_API_KEY=
# Optional separate key; falls back to GOOGLE_PLACES_API_KEY when blank.
GOOGLE_WEATHER_API_KEY=

# PayPal sandbox. Leave blank to use the demo checkout path.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox

# Vocal Bridge deployment. Account-level keys also require the agent UUID.
VOCAL_BRIDGE_API_KEY=
VOCAL_BRIDGE_API_URL=https://vocalbridgeai.com
VOCAL_BRIDGE_AGENT_ID=

# Landing AI (optional bonus receipt OCR)
LANDING_AI_API_KEY=
LANDING_AI_ENDPOINT=
